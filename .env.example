# Required (Supabase)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional (Supabase admin — server only)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Optional (Email via Resend)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="AiWorkers <noreply@yourdomain.com>"

# Optional (OpenClaw provider — AiWorkers calls this host)
OPENCLAW_BASE_URL="https://api.your-openclaw-provider.com"
OPENCLAW_TIMEOUT_MS="45000"

# Optional legacy single shared secret for POST /api/openclaw/tools/run and /api/v1/cloud/tools/run
# (constant-time compare). Prefer per-org tokens via POST /api/admin/cloud-api-tokens (stored hashed in DB).
OPENCLAW_API_KEY="YOUR_OPENCLAW_API_KEY"

# Optional (Internal LLM planner/executor via OpenAI-compatible API)
INTERNAL_LLM_PROVIDER="openai"
INTERNAL_LLM_API_KEY="sk-..."
INTERNAL_LLM_MODEL="gpt-4o-mini"
# Optional override; default uses OpenAI API
INTERNAL_LLM_BASE_URL="https://api.openai.com/v1"

# Optional (Analytics via PostHog)
POSTHOG_API_KEY="phc_..."
POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_POSTHOG_API_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Optional (App)
APP_BASE_URL="http://localhost:3000"
PUBLIC_LEAD_ORGANIZATION_ID="YOUR_PUBLIC_LEAD_ORG_UUID"
PUBLIC_LEAD_CAMPAIGN_ID="YOUR_PUBLIC_LEAD_CAMPAIGN_UUID"

# Optional (Cron / internal routes protection)
CRON_SECRET="replace-with-a-long-random-string"

# Optional (Google OAuth for Analytics/Search Console connection)
GOOGLE_OAUTH_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"

# Optional (Affiliate postback security)
POSTBACK_SECRET="replace-with-a-long-random-string"

# Optional (encrypt org ad platform credentials)
# 32+ chars recommended. Rotate carefully (would require re-encrypting stored creds).
PLATFORM_CREDENTIALS_ENCRYPTION_KEY="replace-with-a-long-random-string"

# Optional (GitHub Actions migration automation)
GITHUB_ACTIONS_TOKEN="ghp_..."
GITHUB_REPO_OWNER="digimiami"
GITHUB_REPO_NAME="AI-Workers-Marketing"
GITHUB_MIGRATIONS_WORKFLOW_FILE="supabase-db-push.yml"
GITHUB_MIGRATIONS_REF="master"

# Optional (Zapier MCP remote Streamable HTTP server)
ZAPIER_MCP_SERVER_URL="https://mcp.zapier.com/..."
ZAPIER_MCP_SECRET="replace-with-a-long-random-string"

# Optional (Dev/CI)
SKIP_ENV_VALIDATION="0"
